[Unit]
Description=Pixal3D Gradio demo
After=network-online.target

[Service]
Type=simple
WorkingDirectory={{PIXAL3D_ROOT}}
Environment=PATH=/usr/local/cuda-13.0/bin:{{PIXAL3D_ROOT}}/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=CUDA_HOME=/usr/local/cuda-13.0
Environment=TORCH_CUDA_ARCH_LIST=12.1
Environment=ATTN_BACKEND=sdpa
Environment=LOW_VRAM=1
Environment=PIXAL3D_REMBG_MODEL=ZhengPeng7/BiRefNet
Environment=GRADIO_SERVER_NAME=0.0.0.0
Environment=GRADIO_SERVER_PORT=7863
Environment=HF_HOME={{PIXAL3D_ROOT}}/hf-cache
Environment=PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
ExecStart={{PIXAL3D_ROOT}}/.venv/bin/python app.py --low_vram --server_name 0.0.0.0 --server_port 7863
Restart=always
RestartSec=5
TimeoutStartSec=900

[Install]
WantedBy=default.target
